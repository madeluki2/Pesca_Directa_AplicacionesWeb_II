# Puerto donde escucha el servidor HTTP.
PUERTO=8080

# Ruta del archivo SQLite para desarrollo local.
RUTA_DB=pesca.db

# Backend de almacenamiento: "gorm" usa SQLite local, "memoria" usa RAM.
# En docker-compose se usa STORAGE=postgres para conectar PostgreSQL.
STORAGE=gorm

# Clave secreta para firmar los tokens JWT.
# En produccion cambia este valor por uno largo, aleatorio y unico.
JWT_SECRETO=pesca-directa-tarqui-secret-2026

# Duracion de validez del token (formato Go: 24h, 30m, 1h30m).
JWT_DURACION=24h
