# Puerto donde escucha el servidor HTTP.
PUERTO=8080

# Ruta del archivo SQLite.
# Local:  pesca.db  (se crea en el directorio donde corres go run)
# Docker: /app/data/pesca.db  (el volumen lo persiste)
RUTA_DB=pesca.db

# Backend de almacenamiento: "gorm" (SQLite persistente) o "memoria" (RAM).
STORAGE=gorm

# Clave secreta para firmar los tokens JWT.
# EN PRODUCCIÓN: cambia este valor por uno largo, aleatorio y único.
JWT_SECRETO=pesca-directa-tarqui-secret-2026

# Duración de validez del token (formato Go: 24h, 30m, 1h30m).
JWT_DURACION=24h